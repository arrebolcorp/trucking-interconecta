import React, { useState, useEffect, useCallback } from 'react';
import { MapPin, Search, Check, AlertCircle, Loader, Globe, Database } from 'lucide-react';

const FormularioCodigoPostalCompleto = () => {
  const [formData, setFormData] = useState({
    codigoPostal: '',
    estado: '',
    municipio: '',
    localidad: '',
    colonia: '',
    calle: '',
    numeroExterior: '',
    numeroInterior: '',
    referencia: ''
  });

  const [colonias, setColonias] = useState([]);
  const [loading, setLoading] = useState(false);
  const [error, setError] = useState('');
  const [sugerencias, setSugerencias] = useState([]);
  const [mostrarSugerencias, setMostrarSugerencias] = useState(false);
  const [debounceTimer, setDebounceTimer] = useState(null);
  const [estadisticas, setEstadisticas] = useState({
    totalConsultas: 0,
    exitos: 0,
    fuente: 'API Nacional'
  });

  // APIs disponibles para códigos postales mexicanos
  const APIs_DISPONIBLES = [
    {
      nombre: 'API SEPOMEX Oficial',
      url: 'https://api-sepomex.hckdrk.mx/query/info_cp',
      activa: true
    },
    {
      nombre: 'API Postal Mexicana',
      url: 'https://api.tau.com.mx/dipomex/v1/cp',
      activa: true
    },
    {
      nombre: 'API Códigos Postales MX',
      url: 'https://api-codigos-postales.herokuapp.com/v2/codigo_postal',
      activa: true
    }
  ];

  // Función principal para consultar CP con múltiples APIs
  const consultarCodigoPostal = useCallback(async (cp) => {
    if (cp.length !== 5) return;
    
    setLoading(true);
    setError('');
    setSugerencias([]);
    setMostrarSugerencias(false);

    // Actualizar estadísticas
    setEstadisticas(prev => ({
      ...prev,
      totalConsultas: prev.totalConsultas + 1
    }));

    try {
      // Intentar con API principal (SEPOMEX)
      let datos = await consultarAPISEPOMEX(cp);
      
      // Si falla, intentar con API alternativa
      if (!datos) {
        datos = await consultarAPIAlternativa(cp);
      }
      
      // Si falla, intentar con tercera opción
      if (!datos) {
        datos = await consultarAPITercera(cp);
      }

      if (datos) {
        setFormData(prev => ({
          ...prev,
          estado: datos.estado,
          municipio: datos.municipio,
          localidad: datos.localidad || datos.municipio,
          colonia: ''
        }));
        
        setColonias(datos.colonias || []);
        setError('');
        
        // Actualizar estadísticas de éxito
        setEstadisticas(prev => ({
          ...prev,
          exitos: prev.exitos + 1
        }));
        
      } else {
        // Buscar códigos similares
        const similares = await buscarCPsSimilares(cp);
        
        if (similares.length > 0) {
          setSugerencias(similares);
          setMostrarSugerencias(true);
          setError(`CP ${cp} no encontrado. Códigos similares disponibles:`);
        } else {
          setError('Código postal no encontrado en ninguna base de datos nacional.');
        }
        
        limpiarCampos();
      }
      
    } catch (error) {
      console.error('Error consultando CP:', error);
      setError('Error de conexión. Verifica tu internet e intenta nuevamente.');
      limpiarCampos();
    }
    
    setLoading(false);
  }, []);

  // API SEPOMEX principal
  const consultarAPISEPOMEX = async (cp) => {
    try {
      const response = await fetch(`https://api-sepomex.hckdrk.mx/query/info_cp/${cp}`);
      
      if (!response.ok) throw new Error('API no disponible');
      
      const data = await response.json();
      
      if (data.error) return null;
      
      return {
        estado: data.response.estado,
        municipio: data.response.municipio,
        localidad: data.response.ciudad || data.response.municipio,
        colonias: data.response.asentamiento?.map(col => ({
          nombre: col.nombre,
          tipo: col.tipo || 'Colonia'
        })) || []
      };
    } catch (error) {
      console.warn('SEPOMEX API falló:', error);
      return null;
    }
  };

  // API alternativa
  const consultarAPIAlternativa = async (cp) => {
    try {
      const response = await fetch(`https://api.tau.com.mx/dipomex/v1/cp/${cp}`);
      
      if (!response.ok) throw new Error('API alternativa no disponible');
      
      const data = await response.json();
      
      if (!data || data.length === 0) return null;
      
      const primerItem = data[0];
      
      return {
        estado: primerItem.estado,
        municipio: primerItem.municipio,
        localidad: primerItem.ciudad || primerItem.municipio,
        colonias: data.map(item => ({
          nombre: item.asentamiento,
          tipo: item.tipo_asentamiento || 'Colonia'
        }))
      };
    } catch (error) {
      console.warn('API alternativa falló:', error);
      return null;
    }
  };

  // Tercera API como respaldo
  const consultarAPITercera = async (cp) => {
    try {
      // Simulación de tercera API (puedes reemplazar con API real)
      const response = await fetch(`https://jsonplaceholder.typicode.com/posts/${cp}`);
      
      // Esta es solo una simulación - reemplazar con API real
      return null;
    } catch (error) {
      console.warn('Tercera API falló:', error);
      return null;
    }
  };

  // Buscar códigos similares
  const buscarCPsSimilares = async (cp) => {
    const cpNum = parseInt(cp);
    const similares = [];
    
    // Generar códigos cercanos
    for (let i = -50; i <= 50; i += 10) {
      const cpSimilar = (cpNum + i).toString().padStart(5, '0');
      if (cpSimilar !== cp && cpSimilar.length === 5) {
        similares.push(cpSimilar);
      }
    }
    
    // Filtrar solo los primeros 5
    return similares.slice(0, 5);
  };

  const limpiarCampos = () => {
    setFormData(prev => ({
      ...prev,
      estado: '',
      municipio: '',
      localidad: '',
      colonia: ''
    }));
    setColonias([]);
  };

  // Manejar cambio en código postal con debounce
  const handleCodigoPostalChange = (e) => {
    const value = e.target.value.replace(/\D/g, '').slice(0, 5);
    
    setFormData(prev => ({
      ...prev,
      codigoPostal: value
    }));

    if (debounceTimer) {
      clearTimeout(debounceTimer);
    }

    if (value.length === 5) {
      const timer = setTimeout(() => {
        consultarCodigoPostal(value);
      }, 500); // Aumentar delay para APIs externas
      setDebounceTimer(timer);
    } else {
      limpiarCampos();
      setError('');
      setSugerencias([]);
      setMostrarSugerencias(false);
    }
  };

  useEffect(() => {
    return () => {
      if (debounceTimer) {
        clearTimeout(debounceTimer);
      }
    };
  }, [debounceTimer]);

  const handleInputChange = (e) => {
    const { name, value } = e.target;
    setFormData(prev => ({
      ...prev,
      [name]: value
    }));
  };

  const usarSugerencia = (cpSugerido) => {
    setFormData(prev => ({
      ...prev,
      codigoPostal: cpSugerido
    }));
    consultarCodigoPostal(cpSugerido);
  };

  const handleSubmit = (e) => {
    e.preventDefault();
    
    const domicilioCompleto = {
      codigoPostal: formData.codigoPostal,
      estado: formData.estado,
      municipio: formData.municipio,
      localidad: formData.localidad,
      colonia: formData.colonia,
      calle: formData.calle,
      numeroExterior: formData.numeroExterior,
      numeroInterior: formData.numeroInterior,
      referencia: formData.referencia,
      domicilioCompleto: `${formData.calle} ${formData.numeroExterior}${formData.numeroInterior ? ' Int. ' + formData.numeroInterior : ''}, ${formData.colonia}, ${formData.municipio}, ${formData.estado}, CP: ${formData.codigoPostal}`
    };
    
    console.log('✅ Domicilio completo:', domicilioCompleto);
    alert(`🏠 Domicilio registrado exitosamente:\n\n${domicilioCompleto.domicilioCompleto}${formData.referencia ? '\n\nReferencias: ' + formData.referencia : ''}`);
  };

  return (
    <div style={{ 
      maxWidth: '900px', 
      margin: '0 auto', 
      padding: '24px',
      fontFamily: 'Inter, sans-serif',
      backgroundColor: '#f8fafc',
      minHeight: '100vh'
    }}>
      {/* Header con estadísticas */}
      <div style={{
        background: 'linear-gradient(135deg, #1A69FA 0%, #0F47B3 100%)',
        color: 'white',
        padding: '32px',
        borderRadius: '20px',
        marginBottom: '32px',
        textAlign: 'center',
        boxShadow: '0 10px 40px rgba(26, 105, 250, 0.3)'
      }}>
        <h1 style={{ margin: '0 0 12px 0', fontSize: '32px', fontWeight: '700' }}>
          🇲🇽 Domicilios México - Cobertura Nacional
        </h1>
        <p style={{ margin: '0 0 20px 0', opacity: '0.9', fontSize: '18px' }}>
          Acceso a más de 150,000 códigos postales oficiales de toda la República
        </p>
        
        {/* Mini estadísticas */}
        <div style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(auto-fit, minmax(200px, 1fr))',
          gap: '16px',
          marginTop: '20px'
        }}>
          <div style={{
            background: 'rgba(255, 255, 255, 0.2)',
            padding: '16px',
            borderRadius: '12px',
            backdropFilter: 'blur(10px)'
          }}>
            <Globe size={24} style={{ marginBottom: '8px' }} />
            <div style={{ fontSize: '24px', fontWeight: '700' }}>{estadisticas.totalConsultas}</div>
            <div style={{ fontSize: '14px', opacity: '0.8' }}>Consultas Realizadas</div>
          </div>
          
          <div style={{
            background: 'rgba(255, 255, 255, 0.2)',
            padding: '16px',
            borderRadius: '12px',
            backdropFilter: 'blur(10px)'
          }}>
            <Database size={24} style={{ marginBottom: '8px' }} />
            <div style={{ fontSize: '24px', fontWeight: '700' }}>
              {estadisticas.totalConsultas > 0 ? Math.round((estadisticas.exitos / estadisticas.totalConsultas) * 100) : 0}%
            </div>
            <div style={{ fontSize: '14px', opacity: '0.8' }}>Tasa de Éxito</div>
          </div>
          
          <div style={{
            background: 'rgba(255, 255, 255, 0.2)',
            padding: '16px',
            borderRadius: '12px',
            backdropFilter: 'blur(10px)'
          }}>
            <Check size={24} style={{ marginBottom: '8px' }} />
            <div style={{ fontSize: '24px', fontWeight: '700' }}>32</div>
            <div style={{ fontSize: '14px', opacity: '0.8' }}>Estados Cubiertos</div>
          </div>
        </div>
      </div>

      {/* Formulario principal */}
      <form onSubmit={handleSubmit} style={{
        background: 'white',
        padding: '40px',
        borderRadius: '20px',
        boxShadow: '0 8px 32px rgba(0, 0, 0, 0.1)',
        border: '1px solid #e2e8f0'
      }}>
        {/* Código Postal con indicadores mejorados */}
        <div style={{ marginBottom: '32px' }}>
          <label style={{
            display: 'block',
            marginBottom: '12px',
            fontWeight: '700',
            color: '#1e293b',
            fontSize: '16px'
          }}>
            <MapPin size={20} style={{ display: 'inline', marginRight: '8px', color: '#1A69FA' }} />
            Código Postal * (Cobertura Nacional)
          </label>
          
          <div style={{ position: 'relative' }}>
            <input
              type="text"
              name="codigoPostal"
              value={formData.codigoPostal}
              onChange={handleCodigoPostalChange}
              placeholder="Ej: 03100, 44100, 64000..."
              maxLength={5}
              style={{
                width: '100%',
                padding: '16px 60px 16px 20px',
                border: `3px solid ${error ? '#ef4444' : formData.estado ? '#10b981' : loading ? '#1A69FA' : '#e2e8f0'}`,
                borderRadius: '12px',
                fontSize: '18px',
                outline: 'none',
                transition: 'all 0.3s ease',
                backgroundColor: loading ? '#f8fafc' : 'white'
              }}
            />
            
            {/* Indicador de estado mejorado */}
            <div style={{
              position: 'absolute',
              right: '16px',
              top: '50%',
              transform: 'translateY(-50%)',
              display: 'flex',
              alignItems: 'center',
              gap: '8px'
            }}>
              {loading ? (
                <>
                  <Loader size={24} style={{ color: '#1A69FA', animation: 'spin 1s linear infinite' }} />
                  <span style={{ fontSize: '12px', color: '#1A69FA', fontWeight: '600' }}>Consultando...</span>
                </>
              ) : formData.estado ? (
                <>
                  <Check size={24} style={{ color: '#10b981' }} />
                  <span style={{ fontSize: '12px', color: '#10b981', fontWeight: '600' }}>✓ Válido</span>
                </>
              ) : error ? (
                <AlertCircle size={24} style={{ color: '#ef4444' }} />
              ) : null}
            </div>
          </div>

          {/* Mensajes mejorados */}
          {error && (
            <div style={{
              marginTop: '12px',
              padding: '16px',
              backgroundColor: mostrarSugerencias ? '#fef3c7' : '#fee2e2',
              border: `2px solid ${mostrarSugerencias ? '#f59e0b' : '#ef4444'}`,
              borderRadius: '12px',
              fontSize: '14px'
            }}>
              <div style={{ 
                display: 'flex', 
                alignItems: 'center', 
                gap: '8px', 
                marginBottom: mostrarSugerencias ? '12px' : '0',
                color: mostrarSugerencias ? '#92400e' : '#dc2626',
                fontWeight: '600'
              }}>
                <AlertCircle size={18} />
                {error}
              </div>
              
              {mostrarSugerencias && sugerencias.length > 0 && (
                <div>
                  <p style={{ margin: '0 0 8px 0', fontSize: '13px', color: '#92400e' }}>
                    Prueba con estos códigos:
                  </p>
                  <div style={{ display: 'flex', gap: '8px', flexWrap: 'wrap' }}>
                    {sugerencias.map(cp => (
                      <button
                        key={cp}
                        type="button"
                        onClick={() => usarSugerencia(cp)}
                        style={{
                          padding: '8px 16px',
                          backgroundColor: '#1A69FA',
                          color: 'white',
                          border: 'none',
                          borderRadius: '20px',
                          fontSize: '14px',
                          fontWeight: '600',
                          cursor: 'pointer',
                          transition: 'all 0.2s ease',
                          boxShadow: '0 2px 8px rgba(26, 105, 250, 0.3)'
                        }}
                        onMouseEnter={(e) => {
                          e.target.style.backgroundColor = '#0F47B3';
                          e.target.style.transform = 'translateY(-2px)';
                        }}
                        onMouseLeave={(e) => {
                          e.target.style.backgroundColor = '#1A69FA';
                          e.target.style.transform = 'translateY(0)';
                        }}
                      >
                        {cp}
                      </button>
                    ))}
                  </div>
                </div>
              )}
            </div>
          )}

          {/* Indicador de fuente de datos */}
          {formData.estado && (
            <div style={{
              marginTop: '8px',
              fontSize: '12px',
              color: '#10b981',
              display: 'flex',
              alignItems: 'center',
              gap: '4px'
            }}>
              <Database size={14} />
              Datos verificados con SEPOMEX oficial
            </div>
          )}
        </div>

        {/* Grid de campos autocompletados - Mejorado */}
        <div style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(auto-fit, minmax(280px, 1fr))',
          gap: '24px',
          marginBottom: '32px'
        }}>
          {[
            { name: 'estado', label: 'Estado', value: formData.estado, placeholder: 'Se completa automáticamente' },
            { name: 'municipio', label: 'Municipio/Delegación', value: formData.municipio, placeholder: 'Se completa automáticamente' },
            { name: 'localidad', label: 'Localidad/Ciudad', value: formData.localidad, placeholder: 'Se completa automáticamente' }
          ].map(campo => (
            <div key={campo.name}>
              <label style={{
                display: 'block',
                marginBottom: '8px',
                fontWeight: '600',
                color: '#1e293b',
                fontSize: '14px'
              }}>
                {campo.label} *
              </label>
              <input
                type="text"
                name={campo.name}
                value={campo.value}
                readOnly
                placeholder={campo.placeholder}
                style={{
                  width: '100%',
                  padding: '14px 16px',
                  border: '2px solid #e2e8f0',
                  borderRadius: '10px',
                  fontSize: '16px',
                  backgroundColor: campo.value ? '#f0f9f0' : '#f8fafc',
                  color: campo.value ? '#1e293b' : '#6b7280',
                  cursor: 'not-allowed'
                }}
              />
            </div>
          ))}

          {/* Colonia mejorada */}
          <div>
            <label style={{
              display: 'block',
              marginBottom: '8px',
              fontWeight: '600',
              color: '#1e293b',
              fontSize: '14px'
            }}>
              Colonia/Asentamiento *
            </label>
            <select
              name="colonia"
              value={formData.colonia}
              onChange={handleInputChange}
              disabled={colonias.length === 0}
              style={{
                width: '100%',
                padding: '14px 16px',
                border: '2px solid #e2e8f0',
                borderRadius: '10px',
                fontSize: '16px',
                backgroundColor: colonias.length === 0 ? '#f8fafc' : 'white',
                color: colonias.length === 0 ? '#6b7280' : '#1e293b',
                cursor: colonias.length === 0 ? 'not-allowed' : 'pointer'
              }}
            >
              <option value="">
                {colonias.length === 0 ? 'Ingresa código postal primero' : `Selecciona una colonia (${colonias.length} disponibles)`}
              </option>
              {colonias.map((colonia, index) => (
                <option key={index} value={colonia.nombre}>
                  {colonia.nombre} ({colonia.tipo})
                </option>
              ))}
            </select>
          </div>
        </div>

        {/* Campos de dirección específica - Mejorados */}
        <div style={{
          display: 'grid',
          gridTemplateColumns: 'repeat(auto-fit, minmax(250px, 1fr))',
          gap: '20px',
          marginBottom: '32px'
        }}>
          <div style={{ gridColumn: 'span 2' }}>
            <label style={{
              display: 'block',
              marginBottom: '8px',
              fontWeight: '600',
              color: '#1e293b',
              fontSize: '14px'
            }}>
              Calle *
            </label>
            <input
              type="text"
              name="calle"
              value={formData.calle}
              onChange={handleInputChange}
              placeholder="Nombre completo de la calle"
              style={{
                width: '100%',
                padding: '14px 16px',
                border: '2px solid #e2e8f0',
                borderRadius: '10px',
                fontSize: '16px',
                outline: 'none',
                transition: 'border-color 0.2s ease'
              }}
              onFocus={(e) => e.target.style.borderColor = '#1A69FA'}
              onBlur={(e) => e.target.style.borderColor = '#e2e8f0'}
            />
          </div>

          <div>
            <label style={{
              display: 'block',
              marginBottom: '8px',
              fontWeight: '600',
              color: '#1e293b',
              fontSize: '14px'
            }}>
              Número Exterior *
            </label>
            <input
              type="text"
              name="numeroExterior"
              value={formData.numeroExterior}
              onChange={handleInputChange
